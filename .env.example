# Supabase — obtener desde Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# CRM — token compartido para que Vercel Cron pueda llamar a /api/crm/cron/reschedule.
# Generar con: openssl rand -hex 32
# Configurar también en Vercel → Project Settings → Environment Variables.
CRON_SECRET=replace-with-a-long-random-string

# Opcional — URL canónica del sitio en producción (Open Graph / metadataBase).
# Si no se setea, layout.tsx cae a NEXT_PUBLIC_VERCEL_URL y luego a localhost.
# NEXT_PUBLIC_SITE_URL=https://leonardoguzman.com.ar
